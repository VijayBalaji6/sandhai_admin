# Copy this file to qa.env (same folder) and fill in real values.
# No spaces around "=". Used when ENV=qa (default) or after merging below.
#
#   cp env/qa.env.example env/qa.env
#
# For CI / GitHub Pages, pass at build time instead:
#   --dart-define=SUPABASE_URL=https://xxxx.supabase.co
#   --dart-define=SUPABASE_ANON_KEY=eyJ...

ENV=qa
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
